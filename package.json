{
  "name": "hero-stand-3d",
  "version": "0.1.2",
  "description": "A reusable 3D standing hero block with mouse-rotate interaction.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./style.css"
  },
  "files": [
    "dist",
    "style.css",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react --external react-dom",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react --external react-dom",
    "check": "tsc --noEmit",
    "demo": "vite demo",
    "demo:build": "vite build demo",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "hero",
    "3d",
    "tilt",
    "mouse",
    "parallax",
    "card"
  ],
  "author": "",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.6.3",
    "vite": "^7.0.5"
  }
}
